@page "/"
@layout LandingLayout
@using Microsoft.AspNetCore.Components.WebAssembly.Hosting
@inject IWebAssemblyHostEnvironment HostEnv

<PageTitle>Hello World</PageTitle>
<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">

    <MudText Typo="Typo.h4" GutterBottom="true">
        Hello, world!
    </MudText>

    <MudText Typo="Typo.body1" Class="mb-4">
        Welcome to your UI Test app.
    </MudText>

    <Component1 />

    <MudStack Spacing="4">

        <!-- Environment info -->
        @if (HostEnv.IsDevelopment())
        {
            <MudAlert Severity="Severity.Info">
                Detailed error info (Development mode)
            </MudAlert>
        }
        else
        {
            <MudAlert Severity="Severity.Warning">
                A generic error occurred. Please try again later.
            </MudAlert>
        }

        <!-- Header -->
        <MudStack Spacing="1">
            <MudText Typo="Typo.h3">Hello, world!</MudText>
            <MudText Typo="Typo.body1">
                Welcome to your new app, powered by MudBlazor and the .NET 9 Template!
            </MudText>
        </MudStack>

        <!-- Docs link -->
        <MudAlert Severity="Severity.Normal">
            You can find documentation and examples on our website:
            <MudLink Href="https://mudblazor.com"
                     Target="_blank"
                     Typo="Typo.body2"
                     Color="Color.Primary">
                <b>mudblazor.com</b>
            </MudLink>
        </MudAlert>

        <MudDivider />

        <!-- Interactivity section -->
        <MudStack Spacing="2">
            <MudText Typo="Typo.h5">Interactivity in this Template</MudText>

            <MudText Typo="Typo.body2">
                When you opt for the <b>Global</b> interactivity location,
                render modes are defined in <code>App.razor</code> and apply to all child components.
                Providers are globally configured in the <code>MainLayout</code>.
            </MudText>

            <MudText Typo="Typo.body2">
                If you choose <b>Per page/component</b> interactivity,
                the following providers must be included on each interactive page:
            </MudText>

            <MudPaper Elevation="0" Class="pa-3">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.body2">&lt;MudPopoverProvider /&gt;</MudText>
                    <MudText Typo="Typo.body2">&lt;MudDialogProvider /&gt;</MudText>
                    <MudText Typo="Typo.body2">&lt;MudSnackbarProvider /&gt;</MudText>
                </MudStack>
            </MudPaper>

            <MudText Typo="Typo.body2">
                Pages without a specified render mode default to <b>Server-Side Rendering (SSR)</b>.
                While MudBlazor supports SSR, interactive components such as buttons and menus
                will not function unless interactivity is enabled.
            </MudText>
        </MudStack>

        <MudDivider />

        <!-- What's new -->
        <MudStack Spacing="3">
            <MudText Typo="Typo.h5">What’s New in Blazor (.NET 9)</MudText>

            <!-- Prerendering -->
            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.h6">Prerendering</MudText>
                        <MudText Typo="Typo.body2">
                            In .NET 9, every Blazor page is prerendered on the server
                            regardless of the selected render mode.
                        </MudText>
                        <MudText Typo="Typo.body2">
                            This means all required services must be available server-side,
                            even when using WebAssembly.
                        </MudText>
                        <MudText Typo="Typo.body2">
                            Prerendering improves perceived performance and initial load times.
                        </MudText>

                        <MudLink Href="https://github.com/dotnet/aspnetcore/issues/51468#issuecomment-1783568121"
                                 Target="_blank"
                                 Color="Color.Primary">
                            More details
                        </MudLink>
                    </MudStack>
                </MudItem>
            </MudGrid>

            <!-- InteractiveAuto -->
            <MudStack Spacing="1">
                <MudText Typo="Typo.h6">InteractiveAuto</MudText>
                <MudText Typo="Typo.body2">
                    A discussion on how to achieve this render mode can be found here:
                </MudText>
                <MudLink Href="https://github.com/dotnet/aspnetcore/issues/51468#issue-1950424116"
                         Target="_blank"
                         Color="Color.Primary">
                    More details
                </MudLink>
            </MudStack>
        </MudStack>

    </MudStack>

</MudContainer>